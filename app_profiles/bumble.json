{
  "schema_version": 2,
  "app_id": "bumble",
  "display_name": "Bumble",
  "support_level": "managed_live_send",
  "host_loop_supported": true,
  "host_loop_send_modes": [
    "stage",
    "live"
  ],
  "message_list_observation": [
    "Observe only visible chat rows and top match circles.",
    "Use candidate_key = visible_name when OCR-readable, otherwise row_index_or_match_index + latest_preview_hash/deadline cue + row or avatar visual evidence.",
    "Record visible reply-deadline markers such as 轮到您了, 回复时间, or 小时后失效 before opening a thread.",
    "Opening Move match circles may require opening a prompt page before a normal composer exists."
  ],
  "thread_observation": [
    "Open the requested visible chat row or match circle.",
    "If an Opening Move prompt is visible, record the prompt text and do not assume a normal message thread.",
    "latest_inbound_messages must contain only messages after the user's latest outbound.",
    "Record reply-deadline evidence separately from ordinary chat content."
  ],
  "opening_move_policy": {
    "scope": "bumble_opening_move",
    "female_user": {
      "agent_decision_authority": "none",
      "user_decision_required": [
        "enable_opening_move",
        "skip_opening_move",
        "accept_male_reply",
        "reject_male_reply"
      ],
      "agent_allowed_actions": [
        "observe_opening_move_prompt",
        "summarize_visible_reply",
        "ask_user_to_decide"
      ],
      "agent_disallowed_actions": [
        "enable_opening_move",
        "skip_opening_move",
        "accept_male_reply",
        "reject_male_reply"
      ]
    },
    "male_user": {
      "agent_may_draft_reply": true,
      "requires_user_confirmation_before_send": true,
      "current_harness_stage_supported": true,
      "current_harness_send_supported": true,
      "autonomous_opening_move_send_supported": false,
      "agent_allowed_actions": [
        "draft_opening_move_reply"
      ],
      "agent_disallowed_actions": [
        "send_opening_move_reply_without_user_confirmation",
        "autonomous_opening_move_send"
      ]
    }
  },
  "stage_send_verification": [
    "Managed Bumble draft staging is supported only inside harness bumble send-message.",
    "Paste the draft into a verified Bumble conversation input first; direct typing is only a printable-ASCII fallback when paste does not stage.",
    "After paste, direct typing, or IME space commit, OCR must verify staged text exactly equals payload_text before clicking Send.",
    "Visual send-button or yellow-bubble evidence alone is not exact-text verification.",
    "Opening Move replies still require user confirmation; autonomous Opening Move sending is not supported."
  ],
  "native_gui_harness": {
    "backend": "iphone_mirroring_macos",
    "supported_stage_actions": [
      "doctor",
      "screenshot",
