  "post_send_verification": [
    "Record succeeded only after a fresh Bumble screenshot shows the sent bubble.",
    "The input must no longer show the active Send marker after clicking Send.",
    "If not verifiable, record unknown or block managed send."
  ],
  "known_gui_pitfalls": [
    "Bumble browse-card horizontal swipes can pass or like; do not use horizontal swipes for read-only navigation.",
    "Top match circles and chat rows may expire if the required party does not reply before the visible deadline.",
    "Opening Move pages are not normal chat threads until the reply composer is opened.",
    "Opening Move replies require user confirmation and are not eligible for autonomous Opening Move send.",
    "macOS pbcopy alone may not update iPhone Universal Clipboard; do not treat clipboard state as Bumble staging evidence.",
    "Bumble live send requires either a target-specific text marker such as the visible match name or allowed structural row-to-thread evidence; generic UI text like Opening Move, Aa, GIF, or Send is not enough.",
    "Emoji or otherwise non-OCR nicknames are valid targets in any message-list row; bind the intended row with chat_list_row_to_thread evidence instead of switching to an OCR-friendly conversation.",
    "Visual send-button or yellow-bubble evidence can support diagnosis but cannot replace exact OCR verification of the payload text.",
    "Non-ABC input sources can leave app names in the iOS Spotlight candidate bar; verify the app result after typing before tapping.",
    "Premium gates such as liked-you reveal and plan selection are not agent actions."
  ],
  "unsupported_actions": [
    "like",
