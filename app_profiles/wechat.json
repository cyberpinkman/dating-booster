{
  "schema_version": 2,
  "app_id": "wechat",
  "display_name": "WeChat",
  "support_level": "managed_live_send",
  "host_loop_supported": true,
  "host_loop_send_modes": [
    "stage",
    "live"
  ],
  "message_list_observation": [
    "Use the visible chat list as the message list equivalent.",
    "Only include test contacts explicitly authorized by the user."
  ],
  "thread_observation": [
    "Ignore any history before the user's explicit start marker.",
    "latest_inbound_messages must contain only messages after the latest user outbound inside the test window."
  ],
  "stage_send_verification": [
    "Mac WeChat can usually accept clipboard paste directly.",
    "Verify staged text before pressing Enter or clicking send."
  ],
  "native_gui_harness": {
    "backend": "macos_wechat_desktop",
    "supported_stage_actions": [
      "doctor",
      "screenshot",
      "launch_app",
      "observe_screen",
      "stage_draft"
    ],
    "supported_live_actions": [
      "send_message"
    ],
    "launch_navigation": {
      "intent": "activate_wechat_application",
      "requires_macos_application": "WeChat",
      "steps": [
        "activate_wechat_application"
      ]
    },
    "screen_observation": {
      "target": "wechat_screen",
      "redacts_raw_ocr_text": true,
      "layout_hints": [
        "conversation_window_present",
        "chat_list_present",
        "message_input_marker_present",
        "unread_marker_present"
      ]
    },
    "draft_staging": {
      "intent": "paste_clipboard_into_wechat_input",
      "steps": [
        "copy_draft_to_clipboard",
        "paste_clipboard_into_wechat_input"
      ],
      "does_not_send": true,
      "requires_user_confirmation_before_send": true,
      "verification": "Host must compare the staged text visually before pressing Enter or clicking Send."
    },
    "live_send": {
      "intent": "press_return_after_exact_staged_text_verification",
      "default_enabled": false,
      "requires_authorization_fields": [
        "autonomous_send",
        "live_send",
        "allowed_actions",
        "requires_post_action_verification"
      ],
      "requires_safety_active": true,
      "requires_policy_checked_action_request": true,
      "requires_target_binding_verification": true,
      "requires_exact_staged_text_verification": true,
      "requires_post_action_verification": true,
      "requires_outbound_bubble_verification": true
    },
    "blocked_actions": [
      "send",
      "payments",
      "calls",
      "contact_exchange_without_user"
    ]
  },
  "post_send_verification": [
    "Record succeeded only after the outbound bubble appears."
  ],
  "known_gui_pitfalls": [
    "Desktop chat history may expose unrelated personal history; respect the declared test boundary."
  ],
  "unsupported_actions": [
    "payments",
    "calls",
    "contact_exchange_without_user"
  ],
  "adapter": {
    "backend": "macos_wechat_desktop",
    "module": "dating_boost.apps.wechat.adapter",
    "class_name": "WeChatAdapter",
    "default_window_title": "WeChat"
  },
  "capabilities": {
    "host_loop_supported": true,
    "send_modes": [
      "stage",
      "live"
    ],
    "stage_actions": [
      "doctor",
      "screenshot",
      "launch_app",
      "observe_screen",
      "stage_draft"
    ],
    "live_actions": [
      "send_message"
    ],
    "actions": [
      "doctor",
      "screenshot",
      "launch_app",
      "observe_screen",
      "stage_draft"
    ],
    "workflows": []
  },
  "selectors": {
    "coordinates": {
      "screen_observation": {
        "target": "wechat_screen",
        "redacts_raw_ocr_text": true,
        "layout_hints": [
          "conversation_window_present",
          "chat_list_present",
          "message_input_marker_present",
          "unread_marker_present"
        ]
      },
      "draft_staging": {
        "intent": "paste_clipboard_into_wechat_input",
        "steps": [
          "copy_draft_to_clipboard",
          "paste_clipboard_into_wechat_input"
        ],
        "does_not_send": true,
        "requires_user_confirmation_before_send": true,
        "verification": "Host must compare the staged text visually before pressing Enter or clicking Send."
      },
      "launch_navigation": {
        "intent": "activate_wechat_application",
        "requires_macos_application": "WeChat",
        "steps": [
          "activate_wechat_application"
        ]
      }
    },
    "blocked_actions": [
      "send",
      "payments",
      "calls",
      "contact_exchange_without_user"
    ]
  },
  "target_binding": {
    "requires_target_binding": true,
    "requires_target_specific_marker": false,
    "generic_marker_blacklist": [],
    "visual_only_exact_verification_allowed": false
  },
  "live_send_requirements": {
    "authorization_fields": [
      "autonomous_send",
      "live_send",
      "allowed_actions",
      "requires_post_action_verification"
    ],
    "required_evidence": [
      "staged_text_verified",
      "input_cleared_after_send",
      "post_action_screen_captured",
      "outbound_message_verified"
    ],
    "exact_text_verification": true,
    "post_action_verification": true,
    "outbound_bubble_verification": true,
    "visual_only_exact_verification_allowed": false
  },
  "managed_session": {
    "precheck_failure_status": "paused",
    "precheck_failure_reason": "app_unavailable",
    "precheck_failure_next_host_action": "restore_wechat_or_stop_managed_session",
    "default_max_threads_per_cycle": 5,
    "high_throughput_max_threads_per_cycle": 12,
    "default_max_pages_per_cycle": 1,
    "high_throughput_max_pages_per_cycle": 3,
    "cycle_send_limit": 1,
    "message_list_pagination_supported": true
  },
  "special_policies": {}
}
