      "description": "Open the user's profile preview from the self profile page."
    },
    "profile_photo_navigation": {
      "next_photo_tap_ratio": {"x": 0.86, "y": 0.45},
      "previous_photo_tap_ratio": {"x": 0.14, "y": 0.45},
      "applies_to": ["self_profile_preview", "match_profile_preview", "full_profile"]
    },
    "profile_detail_navigation": {
      "open_full_profile_tap_ratio": {"x": 0.90, "y": 0.82},
      "read_down_wheel": {"x": 0.50, "y": 0.86, "delta_y": -20, "repeats": 18},
      "read_up_wheel": {"x": 0.50, "y": 0.46, "delta_y": 20, "repeats": 18},
      "expand_visible_section_tap_ratio": {"x": 0.50, "y": 0.76},
      "close_full_profile_tap_ratio": {"x": 0.90, "y": 0.08},
      "close_preview_tap_ratio": {"x": 0.90, "y": 0.08}
    },
    "chat_navigation": {
      "open_chats_tab_tap_ratio": {"x": 0.66, "y": 0.94},
      "new_matches_carousel_wheel_left": {"x": 0.56, "y": 0.30, "delta_x": -20, "repeats": 18},
      "new_matches_carousel_wheel_right": {"x": 0.56, "y": 0.30, "delta_x": 20, "repeats": 18},
      "new_match_card_base_tap_ratio": {"x": 0.42, "y": 0.30},
      "conversation_row_base_tap_ratio": {"x": 0.50, "y": 0.30},
      "conversation_avatar_tap_ratio": {"x": 0.14, "y": 0.30},
      "thread_profile_avatar_tap_ratio": {"x": 0.50, "y": 0.14},
      "thread_back_to_chats_tap_ratio": {"x": 0.09, "y": 0.13},
      "reply_required_marker": "等你回应"
    },
    "live_send": {
      "intent": "tap_send_after_exact_staged_text_verification",
      "default_enabled": false,
      "requires_authorization_fields": ["autonomous_send", "live_send", "allowed_actions", "requires_post_action_verification"],
      "requires_safety_active": true,
      "requires_policy_checked_action_request": true,
      "requires_target_binding_verification": true,
      "requires_exact_staged_text_verification": true,
      "requires_post_action_verification": true,
      "requires_outbound_bubble_verification": true
