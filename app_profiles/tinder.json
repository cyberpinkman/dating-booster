{
  "schema_version": 1,
  "app_id": "tinder",
  "display_name": "Tinder",
  "support_level": "managed_live_send",
  "host_loop_supported": true,
  "host_loop_send_modes": ["stage", "live"],
  "message_list_observation": [
    "Observe only visible rows.",
    "Use candidate_key = visible_name + row_index + latest_preview_hash.",
    "Do not draft until the thread has been opened."
  ],
  "thread_observation": [
    "Open the requested candidate thread.",
    "latest_inbound_messages must contain only messages after the user's latest outbound.",
    "Old visible bubbles belong in visible_messages/background only."
  ],
  "stage_send_verification": [
    "Paste Chinese text into the input box; do not rely on direct Chinese typing.",
    "Verify staged text exactly equals payload_text before send.",
    "If input position drifts, exit and reopen the thread."
  ],
  "native_gui_harness": {
    "backend": "iphone_mirroring_macos",
    "supported_stage_actions": [
      "doctor",
      "screenshot",
      "launch_app",
      "observe_screen",
      "open_self_profile",
      "open_self_profile_preview",
      "profile_photo_next",
      "profile_photo_previous",
      "open_full_profile",
      "profile_scroll_down",
      "profile_scroll_up",
      "expand_visible_profile_section",
      "close_full_profile",
      "close_preview",
      "open_chats",
      "matches_carousel_next",
      "matches_carousel_previous",
      "open_new_match",
      "open_conversation",
      "open_thread_profile",
      "return_to_chats"
    ],
    "supported_live_actions": ["send_message"],
    "launch_navigation": {
      "intent": "ios_home_spotlight_search_launch",
      "requires_verified_screen_state": "not_required",
      "steps": ["open_iphone_home_screen", "open_ios_spotlight", "type_app_name_verified", "tap_search_result_icon"],
      "primary_path": ["open_iphone_home_screen", "open_ios_spotlight", "type_app_name_verified", "tap_search_result_icon"],
      "fallback_path": ["open_iphone_home_screen", "open_ios_spotlight", "switch_input_source", "type_app_name_verified", "tap_search_result_icon"]
