{
  "schema_version": 2,
  "app_id": "tashuo",
  "display_name": "她说",
  "support_level": "managed_live_send",
  "host_loop_supported": true,
  "host_loop_send_modes": [
    "stage",
    "live"
  ],
  "message_list_observation": [
    "Observe only visible rows in the 消息 page and the visible 待回答 cards.",
    "Use candidate_key = visible_name when OCR-readable, otherwise row_index_or_gate_index + latest_preview_hash/status cue + row or avatar visual evidence.",
    "Record whether the item is an ordinary conversation, pending question-gate item, or premium/liked-you gate.",
    "Do not open discovery, like, pass, or 飞行 start-chat controls while scanning messages."
  ],
  "thread_observation": [
    "Open the requested visible ordinary chat row before reading messages.",
    "If a 待回答 or question-gate page is visible, record the prompt and do not treat it as an ordinary conversation.",
    "latest_inbound_messages must contain only messages after the user's latest outbound.",
    "Record visible permanent-chat/question-gate markers separately from ordinary chat content."
  ],
  "question_gate_policy": {
    "scope": "tashuo_question_gate",
    "female_user": {
      "agent_decision_authority": "none",
      "user_decision_required": [
        "enable_question",
        "skip_question_gate",
        "accept_male_reply",
        "reject_male_reply"
      ],
      "agent_allowed_actions": [
        "observe_question_prompt",
        "summarize_visible_reply",
        "ask_user_to_decide"
      ],
      "agent_disallowed_actions": [
        "enable_question",
        "skip_question_gate",
        "accept_male_reply",
        "reject_male_reply"
      ]
    },
    "male_user": {
      "agent_may_draft_reply": true,
      "requires_user_confirmation_before_send": true,
      "current_harness_stage_supported": false,
      "current_harness_send_supported": false,
      "autonomous_question_gate_send_supported": false,
      "agent_allowed_actions": [
        "draft_question_gate_reply"
      ],
      "agent_disallowed_actions": [
        "send_question_gate_reply_without_user_confirmation",
        "autonomous_question_gate_send"
      ]
    }
  },
  "stage_send_verification": [
    "Managed TaShuo draft staging is supported only inside harness tashuo send-message.",
    "Paste the draft into a verified TaShuo ordinary conversation input first; direct typing is only a no-newline fallback when paste does not stage, and IME space commit follows direct typing before final verification.",
    "After paste, direct typing, or IME space commit, exact text evidence must verify staged text equals payload_text before pressing Return; mac-ios-app may satisfy this through Accessibility text evidence.",
    "TaShuo ordinary chat sends with Return; there is no Send button to click.",
    "Visible bubble evidence alone is not exact-text verification unless paired with exact text evidence from OCR, Accessibility, or an approved visual verification flow.",
    "Question-gate replies may be drafted for user review, but current harness question-gate staging/sending is not supported."
  ],
